{
  "title": "AI Platform Overview",
  "uid": "ai-platform-overview",
  "editable": true,
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "refresh": "10s",
  "tags": ["ai-platform", "inference"],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(llm_requests_total[1m])",
          "legendFormat": "{{model}} - {{status}}",
          "interval": "10s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(llm_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "interval": "10s"
        },
        {
          "expr": "histogram_quantile(0.95, rate(llm_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "interval": "10s"
        },
        {
          "expr": "histogram_quantile(0.99, rate(llm_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "interval": "10s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Tokens Per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(llm_tokens_per_second_sum[5m]) / rate(llm_tokens_per_second_count[5m])",
          "legendFormat": "tokens/s",
          "interval": "10s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "spanNulls": false,
            "showPoints": "never"
          },
          "color": { "mode": "fixed", "fixedColor": "#7eb8da" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Active Requests",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "llm_active_requests",
          "legendFormat": "active",
          "interval": "10s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 70 }
            ]
          },
          "custom": { "displayMode": "gradient" },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "horizontal"
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "rate(llm_requests_total{status=\"error\"}[5m]) / rate(llm_requests_total[5m]) * 100",
          "legendFormat": "error rate %",
          "interval": "10s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "spanNulls": false,
            "showPoints": "never"
          },
          "color": { "mode": "fixed", "fixedColor": "#e24d42" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Token Count (Prompt vs Completion)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(llm_prompt_tokens_sum[5m])",
          "legendFormat": "prompt tokens/s",
          "interval": "10s"
        },
        {
          "expr": "rate(llm_completion_tokens_sum[5m])",
          "legendFormat": "completion tokens/s",
          "interval": "10s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "HTTP Status Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "llm_requests_total",
          "legendFormat": "{{status}}",
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "displayMode": "auto",
            "reduceOptions": {
              "values": false,
              "calcs": ["sum"],
              "fields": ""
            }
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["sum", "percent"]
        },
        "tooltip": { "mode": "multi" },
        "reduceOptions": {
          "values": false,
          "calcs": ["sum"],
          "fields": ""
        },
        "displayLabels": ["percent", "name"]
      }
    },
    {
      "title": "SLO Compliance (requests < 5s)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(llm_request_duration_seconds_bucket{le=\"5\"}[5m])) / sum(rate(llm_request_duration_seconds_count[5m])) * 100",
          "legendFormat": "SLO %",
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          },
          "color": { "mode": "thresholds" },
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "textMode": "auto",
        "wideLayout": true
      }
    }
  ]
}
